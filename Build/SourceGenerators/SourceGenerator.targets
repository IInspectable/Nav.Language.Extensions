<?xml version="1.0" encoding="utf-8"?>
<Project>

  <!--
    Zentrales Wiring der Nav-Quellgeneratoren nach dem Muster aus Mfv-Peissenberg.Website
    (Build/SourceGenerator.targets): Ein Generator wird per einzelnem <Use…>-Property opt-in
    aktiviert, ohne pro Projekt Analyzer-ProjectReference + CompilerVisibleProperty zu wiederholen.
    Global eingebunden über das Directory.Build.targets in der Repo-Wurzel — greift dadurch auch im
    legacy VS-Extension-Projekt (importiert Microsoft.Common.props/Microsoft.CSharp.targets).

    Opt-in:
      <UseAssemblyInfoGenerator>true</UseAssemblyInfoGenerator>
    aktiviert den AssemblyInfo-Generator (erzeugt die MyAssembly-Konstanten aus den
    git-abgeleiteten Versions-Properties, siehe Build/Version.targets).
  -->
  <ItemGroup Condition="'$(UseAssemblyInfoGenerator)' == 'true'">
    <ProjectReference Include="$(MSBuildThisFileDirectory)Nav.AssemblyInfo.SourceGenerator\Nav.AssemblyInfo.SourceGenerator.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <!-- Die git-abgeleiteten Werte (ComputeGitVersion) für den Generator sichtbar machen. -->
    <CompilerVisibleProperty Include="ProductVersion" />
    <CompilerVisibleProperty Include="AssemblyVersion" />
    <CompilerVisibleProperty Include="ProductVersionInformational" />
    <CompilerVisibleProperty Include="ProductName" />
  </ItemGroup>

</Project>
