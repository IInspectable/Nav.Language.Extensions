    0 TaskKeyword
    T Whitespace        [4-5]         " "
    5 Identifier
    T NewLine           [6-7]         "\n"
    7 OpenBrace
    T NewLine           [8-9]         "\n"
    L Whitespace        [9-13]        "    "
   13 InitKeyword
    T Whitespace        [17-18]       " "
   18 Identifier
    T Whitespace        [20-21]       " "
   21 DoKeyword
    T Whitespace        [23-24]       " "
    T SkippedTokensTrivia[24-25]       """
   25 Identifier
    T Whitespace        [29-30]       " "
   30 Identifier
    T Whitespace        [42-43]       " "
   60 Semicolon
    T NewLine           [61-62]       "\n"
    L Whitespace        [62-66]       "    "
    L SkippedTokensTrivia[66-70]       "exit"
    L Whitespace        [70-71]       " "
   71 Identifier
   73 Semicolon
    T NewLine           [74-75]       "\n"
    L Whitespace        [75-79]       "    "
    L SkippedTokensTrivia[79-83]       "end;"
    L NewLine           [83-84]       "\n"
   84 CloseBrace
    T NewLine           [85-86]       "\n"
