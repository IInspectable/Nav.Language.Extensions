    L DirectiveTrivia   [0-9]         "#if DEBUG"
    L NewLine           [9-11]        "\r\n"
   11 TaskKeyword
    T Whitespace        [15-16]       " "
   16 Identifier
    T NewLine           [17-19]       "\r\n"
   19 OpenBrace
    T NewLine           [20-22]       "\r\n"
    L Whitespace        [22-26]       "    "
   26 InitKeyword
    T Whitespace        [30-31]       " "
   33 Semicolon
    T NewLine           [34-36]       "\r\n"
    L Whitespace        [36-40]       "    "
   40 ExitKeyword
    T Whitespace        [44-45]       " "
   47 Semicolon
    T NewLine           [48-50]       "\r\n"
    L Whitespace        [50-54]       "    "
   54 Identifier
    T Whitespace        [56-57]       " "
   57 GoToEdgeKeyword
    T Whitespace        [60-61]       " "
   63 Semicolon
    T NewLine           [64-66]       "\r\n"
   66 CloseBrace
    T NewLine           [67-69]       "\r\n"
    L DirectiveTrivia   [69-75]       "#endif"
    L NewLine           [75-77]       "\r\n"
   77 EndOfFile
