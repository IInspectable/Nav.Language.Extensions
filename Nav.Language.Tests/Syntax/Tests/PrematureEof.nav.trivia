    0 TaskKeyword
    T Whitespace        [4-5]         " "
    5 Identifier
    T NewLine           [6-8]         "\r\n"
    8 OpenBrace
    T NewLine           [9-11]        "\r\n"
    L Whitespace        [11-15]       "    "
   15 InitKeyword
    T Whitespace        [19-20]       " "
   22 Semicolon
    T NewLine           [23-25]       "\r\n"
    L Whitespace        [25-29]       "    "
   29 ExitKeyword
    T Whitespace        [33-34]       " "
   36 Semicolon
    T NewLine           [37-39]       "\r\n"
    L Whitespace        [39-43]       "    "
   43 Identifier
    T Whitespace        [45-46]       " "
