<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Leerer Seed: die konkreten Binding-Redirects rechnet MSBuild via AutoGenerateBindingRedirects
       aus dem Abhängigkeitsgraph in die .dll.config (nötig für den redirect-losen NUnit-Console-Runner,
       u.a. System.Buffers/System.Collections.Immutable für Roslyns SymbolFinder). -->
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1" />
  </runtime>
</configuration>
