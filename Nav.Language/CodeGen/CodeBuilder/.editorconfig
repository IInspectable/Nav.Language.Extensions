# Der Ordnername „CodeBuilder" ist zugleich der Name der hier liegenden Klasse
# Pharmatechnik.Nav.Language.CodeGen.CodeBuilder. Ein ordner-gematchter Namespace
# „Pharmatechnik.Nav.Language.CodeGen.CodeBuilder" würde das Namespace-Segment über den Typ legen und
# jeden unqualifizierten „CodeBuilder."-Zugriff mehrdeutig/kaputt machen (CS0118/CS0234). Deshalb bleibt
# der Ordner — wie die Geschwister „CodeModel" und „Templates" — im übergeordneten Namespace
# „Pharmatechnik.Nav.Language.CodeGen"; die IDE0130-Konvention (Namespace = Ordnerstruktur) ist in diesem
# einen Ordner nicht anwendbar und wird gezielt abgeschaltet.
[*.cs]
dotnet_diagnostic.IDE0130.severity = none
# ReSharpers eigene Entsprechung zu IDE0130 greift denselben — hier bewusst gebrochenen — Ordner=Namespace-
# Fall; ebenfalls gezielt abschalten.
resharper_check_namespace_highlighting = none
